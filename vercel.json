{
  "version": 2,
  "builds": [
    {
      "src": "api/reward.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/reward",
      "dest": "/api/reward.js"
    },
    {
      "src": "/manifest.json",
      "headers": {
        "Content-Type": "application/manifest+json",
        "Cache-Control": "no-cache, no-store, must-revalidate"
      },
      "dest": "/manifest.json"
    },
    {
      "src": "/sw.js",
      "headers": {
        "Content-Type": "application/javascript",
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Service-Worker-Allowed": "/"
      },
      "dest": "/sw.js"
    },
    {
      "src": "/icon-(192|512)\\.png",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      },
      "dest": "/$0"
    },
    {
      "src": "/index.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "X-Frame-Options": "DENY",
        "X-Content-Type-Options": "nosniff"
      },
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "headers": {
        "X-Frame-Options": "DENY",
        "X-Content-Type-Options": "nosniff"
      },
      "dest": "/index.html"
    }
  ]
}
